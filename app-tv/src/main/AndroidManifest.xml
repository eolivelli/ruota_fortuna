<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- TV apps do not require a touchscreen -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <!-- Declares this app runs on the TV (Leanback) form factor -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:banner="@drawable/tv_banner"
        android:icon="@drawable/tv_banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RuotaTv">
        <activity
            android:name=".TvMainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RuotaTv">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- LEANBACK_LAUNCHER makes it appear on the Android TV home screen -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
